# Frontend environment variables
# Copy to .env.local for local development

# Optional: only needed for Vercel preview URLs (not www.knowhowindia.in).
# Production uses same-origin /api proxy — do NOT set this on Vercel production.
# Local dev: leave unset; Vite proxies /api to http://localhost:3000
# VITE_API_URL=http://localhost:3000
