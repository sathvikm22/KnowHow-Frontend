{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://knowhow-backend-d2gs.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/shipping-policy", "destination": "/privacy-policy", "permanent": true },
    { "source": "/shipping", "destination": "/privacy-policy", "permanent": true },
    { "source": "/terms", "destination": "/terms-and-conditions", "permanent": true },
    { "source": "/terms-of-service", "destination": "/terms-and-conditions", "permanent": true },
    { "source": "/contact", "destination": "/contact-us", "permanent": true },
    { "source": "/cancellations-refunds", "destination": "/terms-and-conditions", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "index, follow" }]
    }
  ]
}
